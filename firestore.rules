rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if true;
    }
    match /sos_reports/{doc} {
      allow read, write: if true;
    }
    match /alerts/{doc} {
      allow read, write: if true;
    }
    match /global_broadcasts/{doc} {
      allow read, write: if true;
    }
    match /safe_zones/{doc} {
      allow read, write: if true;
    }
    match /community/{doc} {
      allow read, write: if true;
    }
    match /incidents/{doc} {
      allow read, write: if true;
    }
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
